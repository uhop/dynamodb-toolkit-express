{
  "name": "dynamodb-toolkit-express",
  "version": "0.1.0",
  "description": "Express adapter for dynamodb-toolkit — mounts the standard REST route pack as Express middleware.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./*": "./src/*"
  },
  "scripts": {
    "test": "tape6 --flags FO",
    "test:bun": "tape6-bun --flags FO",
    "test:deno": "tape6-deno --flags FO",
    "ts-test": "tape6 --flags FO tests/test-*.*ts",
    "ts-test:bun": "tape6-bun --flags FO tests/test-*.*ts",
    "ts-test:deno": "tape6-deno --flags FO tests/test-*.*ts",
    "ts-check": "tsc --noEmit",
    "js-check": "tsc --project tsconfig.check.json",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "tape6": {
    "tests": [
      "/tests/test-*.js",
      "/tests/test-*.mjs"
    ],
    "node": [
      "/tests/test-*.cjs"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/dynamodb-toolkit-express.git"
  },
  "keywords": [
    "aws",
    "dynamodb",
    "aws-sdk",
    "aws-sdk-v3",
    "express",
    "express-middleware",
    "rest",
    "adapter",
    "dynamodb-toolkit",
    "crud",
    "pagination",
    "hooks",
    "http",
    "typescript",
    "esm",
    "zero-dependencies",
    "deno",
    "bun",
    "toolkit",
    "middleware"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (http://lazutkin.com)",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/uhop/dynamodb-toolkit-express/issues"
  },
  "homepage": "https://github.com/uhop/dynamodb-toolkit-express#readme",
  "funding": "https://github.com/sponsors/uhop",
  "llms": "https://raw.githubusercontent.com/uhop/dynamodb-toolkit-express/master/llms.txt",
  "llmsFull": "https://raw.githubusercontent.com/uhop/dynamodb-toolkit-express/master/llms-full.txt",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "dynamodb-toolkit": "^3.1.1",
    "express": "^4.21.0 || ^5.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1031.0",
    "@aws-sdk/lib-dynamodb": "^3.1031.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "dynamodb-toolkit": "^3.1.1",
    "express": "^5.2.1",
    "prettier": "^3.8.1",
    "tape-six": "^1.7.13",
    "typescript": "^6.0.3"
  },
  "files": [
    "src",
    "llms.txt",
    "llms-full.txt"
  ]
}
